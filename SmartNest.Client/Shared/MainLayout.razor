@inherits LayoutComponentBase
@using SmartNest.Client.Services
@inject AuthenticationService Auth
@inject NavigationManager Nav

<div class="layout @(_open ? "nav-open" : "")">

    <aside class="sidenav">
        <div class="sidenav-logo">
            <img src="images/logo.png" alt="Smart-Nest" />
            <span>Smart<em>Nest</em></span>
        </div>

        <nav class="sidenav-links">
            <NavLink href="/" Match="NavLinkMatch.All" @onclick="Close">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8"><rect x="3" y="3" width="7" height="7" rx="1"/><rect x="14" y="3" width="7" height="7" rx="1"/><rect x="3" y="14" width="7" height="7" rx="1"/><rect x="14" y="14" width="7" height="7" rx="1"/></svg>
                <span>Tableau de bord</span>
            </NavLink>
            <NavLink href="/environnement" @onclick="Close">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8"><path d="M14 14.76V3.5a2.5 2.5 0 0 0-5 0v11.26a4.5 4.5 0 1 0 5 0z"/></svg>
                <span>Environnement</span>
            </NavLink>
            <NavLink href="/volailles" @onclick="Close">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8"><circle cx="12" cy="12" r="3"/><path d="M12 2v3M12 19v3M4.22 4.22l2.12 2.12M17.66 17.66l2.12 2.12M2 12h3M19 12h3M4.22 19.78l2.12-2.12M17.66 6.34l2.12-2.12"/></svg>
                <span>Volailles</span>
            </NavLink>
            <NavLink href="/camera" @onclick="Close">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8"><path d="M23 7l-7 5 7 5V7z"/><rect x="1" y="5" width="15" height="14" rx="2"/></svg>
                <span>Surveillance</span>
            </NavLink>
            <NavLink href="/alertes" @onclick="Close">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8"><path d="M18 8A6 6 0 0 0 6 8c0 7-3 9-3 9h18s-3-2-3-9"/><path d="M13.73 21a2 2 0 0 1-3.46 0"/></svg>
                <span>Alertes</span>
            </NavLink>
        </nav>

        <div class="sidenav-user">
            <div class="user-avatar">@(Auth.Username.Length > 0 ? char.ToUpper(Auth.Username[0]).ToString() : "?")</div>
            <div class="user-meta">
                <strong>@Auth.Username</strong>
                <span>@Auth.Role</span>
            </div>
            <button class="btn-signout" title="Déconnexion" @onclick="Logout">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8"><path d="M9 21H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h4"/><polyline points="16 17 21 12 16 7"/><line x1="21" y1="12" x2="9" y2="12"/></svg>
            </button>
        </div>
    </aside>

    <div class="layout-body">
        <header class="topbar">
            <button class="hamburger" @onclick="Toggle">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><line x1="3" y1="6" x2="21" y2="6"/><line x1="3" y1="12" x2="21" y2="12"/><line x1="3" y1="18" x2="21" y2="18"/></svg>
            </button>
            <div class="topbar-right">
                @if (Auth.IsAuthenticated)
                {
                    <span class="topbar-greeting">Bonjour, <strong>@Auth.Username</strong></span>
                }
            </div>
        </header>

        <main class="page-content">
            @Body
        </main>
    </div>
</div>

@if (_open)
{
    <div class="nav-overlay" @onclick="Close"></div>
}

@code {
    private bool _open;
    private void Toggle() => _open = !_open;
    private void Close()  => _open = false;
    private async Task Logout() { await Auth.LogoutAsync(); Nav.NavigateTo("/connexion"); }
}
